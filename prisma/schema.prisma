generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FeedSourceType {
  CURATED
  USER_BLOG
}

enum PostSourceType {
  CURATED_RSS
  USER_SUBMISSION
  USER_BLOG
}

enum SummaryStatus {
  PENDING
  COMPLETE
  FAILED
}

enum ArticleQualityRating {
  COMMON_RUMOUR
  MERCHANTS_WORD
  CAPTAINS_ACCOUNT
  UNDERWRITERS_CONFIDENCE
  LLOYDS_ASSURANCE
}

enum CommentFormat {
  MARKDOWN
  RICH_TEXT
}

enum AvailabilityMode {
  VIRTUAL
  IN_PERSON
  EITHER
}

enum MatchMode {
  VIRTUAL
  IN_PERSON
}

enum MatchStatus {
  PROPOSED
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum CommentModerationDecision {
  ALLOWED
  BLOCKED
}

enum CommentModerationSeverity {
  NONE
  MINOR
  MAJOR
  SEVERE
}

enum CommentModerationPenalty {
  NONE
  SUSPEND_12_HOURS
  SUSPEND_3_DAYS
  SUSPEND_7_DAYS
  SUSPEND_30_DAYS
  BAN_ACCOUNT
}

model User {
  id                  String          @id @default(cuid())
  name                String?
  email               String?         @unique
  emailVerified       DateTime?
  image               String?
  manifestoAcceptedAt DateTime?
  constitutionViolationCount Int      @default(0)
  commentSuspendedUntil DateTime?
  accountBannedAt     DateTime?
  accountBanReason    String?         @db.Text
  timezone            String          @default("UTC")
  headline            String?
  bio                 String?         @db.Text
  interests           String?         @db.Text
  goals               String?         @db.Text
  ideasInFlight       String?         @db.Text
  blogFeedUrl         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  accounts            Account[]
  sessions            Session[]
  authoredPosts       Post[]          @relation("PostSubmittedBy")
  authoredComments    PostComment[]   @relation("PostCommentAuthor")
  availabilities      Availability[]
  profileSignals      ProfileSignal[]
  matchesAsA          Match[]         @relation("MatchUserA")
  matchesAsB          Match[]         @relation("MatchUserB")
  ownedFeedSources    FeedSource[]    @relation("FeedSourceOwner")
  appointmentSchedules AppointmentSchedule[]
  moderationEvents    CommentModerationEvent[]

  @@index([manifestoAcceptedAt])
  @@index([commentSuspendedUntil])
  @@index([accountBannedAt])
}

model Account {
  userId               String
  type                 String
  provider             String
  providerAccountId    String
  refresh_token        String?  @db.Text
  access_token         String?  @db.Text
  expires_at           Int?
  token_type           String?
  scope                String?
  id_token             String?  @db.Text
  session_state        String?
  refresh_token_expires_in Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model FeedSource {
  id           String         @id @default(cuid())
  name         String
  url          String         @unique
  description  String?
  sourceType   FeedSourceType @default(CURATED)
  ownerUserId  String?
  isActive     Boolean        @default(true)
  lastFetchedAt DateTime?
  failureCount Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ownerUser    User?          @relation("FeedSourceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  posts        Post[]

  @@index([isActive, lastFetchedAt])
  @@index([ownerUserId])
}

model Post {
  id                 String         @id @default(cuid())
  title              String
  url                String
  canonicalUrl       String         @unique
  domain             String?
  excerpt            String?        @db.Text
  publishedAt        DateTime?
  sourceType         PostSourceType
  submittedById      String?
  feedSourceId       String?
  summaryStatus      SummaryStatus  @default(PENDING)
  summaryBullets     Json?
  summaryReadSeconds Int?
  summaryModel       String?
  summaryGeneratedAt DateTime?
  summaryError       String?        @db.Text
  qualityRating      ArticleQualityRating?
  qualityRationale   String?        @db.Text
  qualityModel       String?
  qualityScoredAt    DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  submittedBy        User?          @relation("PostSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  feedSource         FeedSource?    @relation(fields: [feedSourceId], references: [id], onDelete: SetNull)
  profileSignals     ProfileSignal[]
  comments           PostComment[]
  moderationEvents   CommentModerationEvent[]

  @@index([publishedAt])
  @@index([createdAt])
  @@index([summaryStatus, createdAt])
  @@index([qualityRating, createdAt])
  @@index([feedSourceId])
}

model PostComment {
  id          String            @id @default(cuid())
  postId      String
  authorId    String
  content     String            @db.Text
  format      CommentFormat     @default(MARKDOWN)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  post        Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  author      User              @relation("PostCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  parentEdges PostCommentEdge[] @relation("PostCommentEdgesChild")
  childEdges  PostCommentEdge[] @relation("PostCommentEdgesParent")

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
}

model PostCommentEdge {
  childCommentId  String
  parentCommentId String
  createdAt       DateTime    @default(now())
  childComment    PostComment @relation("PostCommentEdgesChild", fields: [childCommentId], references: [id], onDelete: Cascade)
  parentComment   PostComment @relation("PostCommentEdgesParent", fields: [parentCommentId], references: [id], onDelete: Cascade)

  @@id([childCommentId, parentCommentId])
  @@index([parentCommentId, createdAt])
}

model CommentModerationEvent {
  id                       String                    @id @default(cuid())
  userId                   String
  postId                   String
  submittedContent         String                    @db.Text
  decision                 CommentModerationDecision
  alignsWithConstitution   Boolean
  severity                 CommentModerationSeverity @default(NONE)
  rationale                String?                   @db.Text
  confidence               Float?
  alignmentScore           Float?
  violationCountAtDecision Int
  penalty                  CommentModerationPenalty  @default(NONE)
  penaltyEndsAt            DateTime?
  model                    String
  createdAt                DateTime                  @default(now())
  user                     User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post                     Post                      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([postId, createdAt])
  @@index([decision, createdAt])
}

model ProfileSignal {
  id           String   @id @default(cuid())
  userId       String
  sourcePostId String?
  signalType   String
  content      String   @db.Text
  score        Float?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePost   Post?    @relation(fields: [sourcePostId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sourcePostId])
}

model Availability {
  id        String           @id @default(cuid())
  userId    String
  startsAt  DateTime
  endsAt    DateTime
  timezone  String
  mode      AvailabilityMode
  location  String?
  notes     String?          @db.Text
  isMatched Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchAsA  Match[]          @relation("MatchAvailabilityA")
  matchAsB  Match[]          @relation("MatchAvailabilityB")

  @@index([userId, startsAt])
  @@index([isMatched, startsAt])
}

model Match {
  id              String      @id @default(cuid())
  userAId         String
  userBId         String
  availabilityAId String
  availabilityBId String
  slotStartsAt    DateTime
  slotEndsAt      DateTime
  mode            MatchMode
  location        String?
  aiRationale     String?     @db.Text
  compatibilityScore Float?
  calendarEventAId String?
  calendarEventBId String?
  status          MatchStatus @default(PROPOSED)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  userA           User        @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB           User        @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  availabilityA   Availability @relation("MatchAvailabilityA", fields: [availabilityAId], references: [id], onDelete: Cascade)
  availabilityB   Availability @relation("MatchAvailabilityB", fields: [availabilityBId], references: [id], onDelete: Cascade)

  @@unique([availabilityAId, availabilityBId])
  @@index([userAId, createdAt])
  @@index([userBId, createdAt])
  @@index([status, createdAt])
}

model AppointmentSchedule {
  id             String   @id @default(cuid())
  userId         String
  label          String
  bookingPageUrl String
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bookingPageUrl])
  @@index([userId, isActive])
}

model JobRun {
  id             String   @id @default(cuid())
  jobType        String
  status         String   @default("RUNNING")
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  itemsProcessed Int      @default(0)
  itemsCreated   Int      @default(0)
  notes          String?  @db.Text

  @@index([jobType, startedAt])
}
