generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FeedSourceType {
  CURATED
  USER_BLOG
}

enum PostSourceType {
  CURATED_RSS
  USER_SUBMISSION
  USER_BLOG
}

enum SummaryStatus {
  PENDING
  COMPLETE
  FAILED
}

enum AvailabilityMode {
  VIRTUAL
  IN_PERSON
  EITHER
}

enum MatchMode {
  VIRTUAL
  IN_PERSON
}

enum MatchStatus {
  PROPOSED
  SCHEDULED
  COMPLETED
  CANCELLED
}

model User {
  id                  String          @id @default(cuid())
  name                String?
  email               String?         @unique
  emailVerified       DateTime?
  image               String?
  manifestoAcceptedAt DateTime?
  timezone            String          @default("UTC")
  headline            String?
  bio                 String?         @db.Text
  interests           String?         @db.Text
  goals               String?         @db.Text
  ideasInFlight       String?         @db.Text
  blogFeedUrl         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  accounts            Account[]
  sessions            Session[]
  authoredPosts       Post[]          @relation("PostSubmittedBy")
  availabilities      Availability[]
  profileSignals      ProfileSignal[]
  matchesAsA          Match[]         @relation("MatchUserA")
  matchesAsB          Match[]         @relation("MatchUserB")
  ownedFeedSources    FeedSource[]    @relation("FeedSourceOwner")

  @@index([manifestoAcceptedAt])
}

model Account {
  userId               String
  type                 String
  provider             String
  providerAccountId    String
  refresh_token        String?  @db.Text
  access_token         String?  @db.Text
  expires_at           Int?
  token_type           String?
  scope                String?
  id_token             String?  @db.Text
  session_state        String?
  refresh_token_expires_in Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model FeedSource {
  id           String         @id @default(cuid())
  name         String
  url          String         @unique
  description  String?
  sourceType   FeedSourceType @default(CURATED)
  ownerUserId  String?
  isActive     Boolean        @default(true)
  lastFetchedAt DateTime?
  failureCount Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ownerUser    User?          @relation("FeedSourceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  posts        Post[]

  @@index([isActive, lastFetchedAt])
  @@index([ownerUserId])
}

model Post {
  id                 String         @id @default(cuid())
  title              String
  url                String
  canonicalUrl       String         @unique
  domain             String?
  excerpt            String?        @db.Text
  publishedAt        DateTime?
  sourceType         PostSourceType
  submittedById      String?
  feedSourceId       String?
  summaryStatus      SummaryStatus  @default(PENDING)
  summaryBullets     Json?
  summaryReadSeconds Int?
  summaryModel       String?
  summaryGeneratedAt DateTime?
  summaryError       String?        @db.Text
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  submittedBy        User?          @relation("PostSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  feedSource         FeedSource?    @relation(fields: [feedSourceId], references: [id], onDelete: SetNull)
  profileSignals     ProfileSignal[]

  @@index([publishedAt])
  @@index([createdAt])
  @@index([summaryStatus, createdAt])
  @@index([feedSourceId])
}

model ProfileSignal {
  id           String   @id @default(cuid())
  userId       String
  sourcePostId String?
  signalType   String
  content      String   @db.Text
  score        Float?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourcePost   Post?    @relation(fields: [sourcePostId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sourcePostId])
}

model Availability {
  id        String           @id @default(cuid())
  userId    String
  startsAt  DateTime
  endsAt    DateTime
  timezone  String
  mode      AvailabilityMode
  location  String?
  notes     String?          @db.Text
  isMatched Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchAsA  Match[]          @relation("MatchAvailabilityA")
  matchAsB  Match[]          @relation("MatchAvailabilityB")

  @@index([userId, startsAt])
  @@index([isMatched, startsAt])
}

model Match {
  id              String      @id @default(cuid())
  userAId         String
  userBId         String
  availabilityAId String
  availabilityBId String
  slotStartsAt    DateTime
  slotEndsAt      DateTime
  mode            MatchMode
  location        String?
  aiRationale     String?     @db.Text
  compatibilityScore Float?
  calendarEventAId String?
  calendarEventBId String?
  status          MatchStatus @default(PROPOSED)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  userA           User        @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB           User        @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  availabilityA   Availability @relation("MatchAvailabilityA", fields: [availabilityAId], references: [id], onDelete: Cascade)
  availabilityB   Availability @relation("MatchAvailabilityB", fields: [availabilityBId], references: [id], onDelete: Cascade)

  @@unique([availabilityAId, availabilityBId])
  @@index([userAId, createdAt])
  @@index([userBId, createdAt])
  @@index([status, createdAt])
}

model JobRun {
  id             String   @id @default(cuid())
  jobType        String
  status         String   @default("RUNNING")
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  itemsProcessed Int      @default(0)
  itemsCreated   Int      @default(0)
  notes          String?  @db.Text

  @@index([jobType, startedAt])
}
