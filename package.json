{
  "name": "lloyds",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:seed": "npm run prisma:seed",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test -c playwright.staging.config.ts --grep @smoke",
    "e2e:staging-acceptance": "playwright test -c playwright.staging.config.ts --grep @acceptance",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "docker:build": "docker build -t lloyds:local .",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.3",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.22.0",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.17.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
