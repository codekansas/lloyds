# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lloyds?schema=public"

# Auth.js
AUTH_SECRET="replace-with-openssl-rand-hex-32"
AUTH_TRUST_HOST="true"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# OpenAI
APP_ENV="development"
OPENAI_API_KEY=""
OPENAI_API_KEY_DEVELOPMENT=""
OPENAI_API_KEY_STAGING=""
OPENAI_API_KEY_PRODUCTION=""
OPENAI_MODEL="gpt-5.1-mini"
OPENAI_CONSTITUTION_GRADER_MODEL="gpt-5.2"

# Job security
CRON_SECRET="replace-with-random-long-secret"

# Notifications (optional)
APP_BASE_URL="http://localhost:3000"
NOTIFICATION_EMAIL_FROM="Lloyd's Coffee House <notifications@example.com>"
RESEND_API_KEY=""

# E2E testing
E2E_TEST_MODE="false"
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3001"
